MAXIO_HTTP_ADDRESS=:8080
MAXIO_HTTP_BODY_LIMIT=1073741824
MAXIO_STORAGE_ADDRESS=127.0.0.1:8080
MAXIO_DATA_DIR=/var/lib/maxio/data
MAXIO_LOG_LEVEL=info

MAXIO_ADMIN_TOKEN=change-me-admin-token
MAXIO_API_TOKEN=

MAXIO_S3_ACCESS_KEY=
MAXIO_S3_SECRET_KEY=
MAXIO_S3_REGION=us-east-1

MAXIO_RAFT_NODE_ID=1
MAXIO_RAFT_SHARD_ID=1
MAXIO_RAFT_ADDRESS=127.0.0.1:63000
MAXIO_RAFT_DATA_DIR=raft
MAXIO_RAFT_BOOTSTRAP=true
MAXIO_RAFT_JOIN=false
MAXIO_RAFT_INITIAL_MEMBERS=
MAXIO_RAFT_OPERATION_TIMEOUT=5s

MAXIO_GOSSIP_BIND_ADDRESS=0.0.0.0:7946
MAXIO_GOSSIP_ADVERTISE_ADDRESS=
MAXIO_GOSSIP_SEEDS=

MAXIO_PENDING_OBJECT_TTL=1h

MAXIO_REPAIR_INTERVAL=10m
MAXIO_REPAIR_ON_START=true
MAXIO_REPAIR_MAX_BATCH=100
MAXIO_REPAIR_MAX_RETRIES=2
MAXIO_REPAIR_RATE_LIMIT=0
MAXIO_REPAIR_RETRY_BACKOFF=1s
MAXIO_REPAIR_RETRY_MAX_BACKOFF=10s
MAXIO_REPAIR_RETRY_MULTIPLIER=2

MAXIO_DEDUPE_INTERVAL=30m
MAXIO_DEDUPE_ON_START=true
MAXIO_DEDUPE_MAX_FIXES=100

MAXIO_INDEX_TIMEOUT=30s
MAXIO_INDEX_RETRY_BACKOFF=1s
MAXIO_INDEX_MAX_RETRIES=2
MAXIO_INDEX_QUEUE_SIZE=1024
MAXIO_INDEX_RATE_LIMIT=0
